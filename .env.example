# =============================================================================
# .env.example — template de variáveis de ambiente (versionado, SEM valores reais)
#
# Uso: copie para um .env local ->  cp .env.example .env
# O .env real é ignorado pelo git (contém segredos).
#
# OBS: hoje o app não lê nenhuma variável de ambiente. Este arquivo serve como
# documentação/ponto de partida para quando você adicionar configuração.
# =============================================================================

# --- Variáveis embutidas NO BUILD (next build) -------------------------------
# Precisam existir na hora do `next build` (no Docker: passe via --build-arg).
# Ficam "congeladas" na imagem — mudar depois exige rebuild.
# NEXT_PUBLIC_API_URL=https://api.exemplo.com

# --- Variáveis de runtime (servidor) -----------------------------------------
# Lidas quando o servidor sobe. Podem ser injetadas no `docker run` / orquestrador.
# Segredos (chaves de API, DB, etc.) SEM prefixo NEXT_PUBLIC_ ficam só no servidor.
# DATABASE_URL=
# API_SECRET=

# --- Infra do container (normalmente NÃO precisa mexer) ----------------------
# Já são definidas no Dockerfile. Listadas aqui só como referência.
# NODE_ENV=production
# PORT=3000
# NEXT_TELEMETRY_DISABLED=1
# HOSTNAME=0.0.0.0   # no Docker deixe 0.0.0.0; ver Dockerfile p/ o porquê
